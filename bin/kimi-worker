#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: $(basename "$0") <worker-name> [cli-args...]" >&2
  exit 1
fi

WORKER_NAME="$1"
shift || true

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
ROOT="$(git -C "$PROJECT_DIR" rev-parse --show-toplevel)"
CONF="$PROJECT_DIR/.parallel/workers/${WORKER_NAME}.conf"

if [[ ! -f "$CONF" ]]; then
  echo "[ERR] worker config not found: $CONF" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$CONF"

resolve_path() {
  python3 - "$ROOT" "$1" <<'PY'
import os,sys
root,rel = sys.argv[1], sys.argv[2]
path = rel if os.path.isabs(rel) else os.path.join(root, rel)
print(os.path.abspath(path))
PY
}

WT_REL="${WORKTREE:-../wt-${WORKER_NAME}}"
WT_ABS="$(resolve_path "$WT_REL")"
TARGET_DIR="$WT_ABS"

if [[ -n "${PROJECT_SUBDIR:-}" && -d "$WT_ABS/$PROJECT_SUBDIR" ]]; then
  TARGET_DIR="$WT_ABS/$PROJECT_SUBDIR"
fi

if [[ ! -d "$TARGET_DIR" ]]; then
  echo "[ERR] worker directory not found: $TARGET_DIR" >&2
  exit 1
fi

cd "$TARGET_DIR"
exec "${CLI_BIN:-kimi}" "$@"
