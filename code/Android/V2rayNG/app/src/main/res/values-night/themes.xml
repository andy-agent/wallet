<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Night theme: inherit the shared AppThemeBase and only override night-specific items -->
    <style name="AppThemeDayNight" parent="AppThemeBase">
        <!-- Night mode specific overrides -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <style name="AppThemeDayNight.ComposeLaunch" parent="AppThemeDayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/compose_launch_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/md_theme_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

</resources>
