<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000">

    <ImageView
        android:id="@+id/launch_static_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/launch_splash_window_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/launch_hub_overlay"
        android:layout_width="164dp"
        android:layout_height="164dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="34dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/launch_hub_glow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/launch_hub_glow" />

        <View
            android:id="@+id/launch_hub_ring_outer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/launch_hub_ring_outer" />

        <View
            android:id="@+id/launch_hub_ring_inner"
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:layout_gravity="center"
            android:background="@drawable/launch_hub_ring_inner" />
    </FrameLayout>

    <ProgressBar
        android:id="@+id/launch_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginStart="27dp"
        android:layout_marginTop="536dp"
        android:layout_marginEnd="27dp"
        android:max="100"
        android:progress="12"
        android:progressDrawable="@drawable/launch_splash_progress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/launch_status_card"
        android:layout_width="0dp"
        android:layout_height="156dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="636dp"
        android:layout_marginEnd="18dp"
        android:background="#FCFFFFFF"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/launch_row_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/launch_row_1_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="安全自托管"
                    android:textColor="#132748"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/launch_row_1_copy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="本地密钥环境与生物识别策略已经装载。"
                    android:textColor="#4D6287"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/launch_row_1_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已就绪"
                android:textColor="#132748"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#1F6880DB" />

        <LinearLayout
            android:id="@+id/launch_row_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/launch_row_2_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="全球加速"
                    android:textColor="#132748"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/launch_row_2_copy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="节点健康探测和智能路由优先级正在同步。"
                    android:textColor="#4D6287"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/launch_row_2_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="同步中"
                android:textColor="#132748"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
