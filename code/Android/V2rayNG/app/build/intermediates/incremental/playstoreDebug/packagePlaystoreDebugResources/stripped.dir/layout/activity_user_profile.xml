<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".payment.ui.activity.UserProfileActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/user_profile" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/layoutUserInfo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <!-- 用户信息卡片 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/md_theme_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp16">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_info"
                            android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                            android:textColor="@color/md_theme_onSurface"
                            android:textStyle="bold" />

                        <!-- 用户名 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp12"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/username"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurfaceVariant" />

                            <TextView
                                android:id="@+id/textUsername"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/padding_spacing_dp8"
                                android:gravity="end"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurface"
                                android:textStyle="bold"
                                tools:text="user123" />

                        </LinearLayout>

                        <!-- 邮箱 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp8"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/email"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurfaceVariant" />

                            <TextView
                                android:id="@+id/textEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/padding_spacing_dp8"
                                android:gravity="end"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurface"
                                tools:text="user@example.com" />

                        </LinearLayout>

                        <!-- 登录时间 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp8"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/login_time"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurfaceVariant" />

                            <TextView
                                android:id="@+id/textLoginTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/padding_spacing_dp8"
                                android:gravity="end"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurface"
                                tools:text="2024-01-01 12:00" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 订阅状态卡片 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/md_theme_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp16">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/subscription_status"
                            android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                            android:textColor="@color/md_theme_onSurface"
                            android:textStyle="bold" />

                        <!-- 到期时间 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp12"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/expiry_time"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurfaceVariant" />

                            <TextView
                                android:id="@+id/textExpiryTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/padding_spacing_dp8"
                                android:gravity="end"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textColor="@color/md_theme_onSurface"
                                android:textStyle="bold"
                                tools:text="2024-12-31 23:59" />

                        </LinearLayout>

                        <!-- 剩余天数 -->
                        <TextView
                            android:id="@+id/textDaysRemaining"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:gravity="end"
                            android:textAppearance="@style/TextAppearance.AppCompat.Small"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="剩余 30 天"
                            tools:visibility="visible" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 订单历史标题 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp24"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/order_history"
                        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                        android:textColor="@color/md_theme_onSurface"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonRefresh"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/refresh"
                        app:icon="@drawable/ic_refresh_24dp"
                        app:iconSize="16dp" />

                </LinearLayout>

                <!-- 订单历史列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_order_history" />

                <!-- 空订单提示 -->
                <TextView
                    android:id="@+id/textEmptyOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp32"
                    android:gravity="center"
                    android:text="@string/no_orders_yet"
                    android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                    android:textColor="@color/md_theme_outline"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- 退出登录按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp32"
                    android:text="@string/logout"
                    app:backgroundTint="@color/md_theme_error"
                    app:icon="@drawable/ic_logout_24dp"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </ScrollView>

        <!-- 未登录状态 -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_spacing_dp16"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="@dimen/view_height_dp64"
                android:layout_height="@dimen/view_height_dp64"
                android:contentDescription="No Data"
                android:alpha="0.5"
                app:srcCompat="@drawable/ic_person_24dp"
                app:tint="@color/md_theme_outline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp16"
                android:text="@string/not_logged_in"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                android:textColor="@color/md_theme_outline" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp16"
                android:text="@string/go_to_login"
                app:icon="@drawable/ic_login_24dp"
                app:iconGravity="textStart" />

        </LinearLayout>

        <!-- 加载状态 -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>

</LinearLayout>
