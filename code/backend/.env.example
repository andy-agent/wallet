PORT=3000
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cryptovpn
REDIS_URL=redis://localhost:6379/0
# Runtime state defaults to Postgres in production and file storage in dev/test.
# Set RUNTIME_STATE_BACKEND=postgres to exercise the Postgres path locally.
# Set RUNTIME_STATE_BACKEND=file to force the file-backed dev/test fallback.
RUNTIME_STATE_FILE=./.runtime/runtime-state.json
AUTH_TOKEN_SECRET=change-me-for-non-dev

# Solana/USDT Chain-side Service Configuration
# Enable/disable real chain calls (default: false for safety)
SOLANA_SERVICE_ENABLED=false
# Base URL for sol/usdt service
SOLANA_SERVICE_URL=http://localhost:8080
# API key for service authentication (optional)
# SOLANA_SERVICE_API_KEY=your_api_key_here
# Real receiving address for client SOLANA orders.
# Required outside tests to avoid synthetic collection addresses.
# SOLANA_ORDER_COLLECTION_ADDRESS=YourRealSolanaReceivingAddress
# Request timeout in milliseconds (default: 30000)
SOLANA_SERVICE_TIMEOUT_MS=30000
# Use devnet instead of mainnet (default: true for safety)
SOLANA_SERVICE_USE_DEVNET=true
# Max retry attempts for failed requests (default: 3)
SOLANA_SERVICE_MAX_RETRIES=3

# TRON chain-side service configuration
TRON_SERVICE_ENABLED=false
TRON_SERVICE_URL=http://localhost:4000/api
# TRON_SERVICE_API_KEY=your_api_key_here
TRON_SERVICE_TIMEOUT_MS=30000
