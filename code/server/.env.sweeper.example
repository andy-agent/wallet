# 资金归集配置示例
# 复制到 .env 文件中并根据实际情况修改

# ========== Sweeper 资金归集配置 ==========

# 是否启用资金归集
SWEEPER_ENABLED=true

# 归集任务执行间隔（分钟）
SWEEPER_INTERVAL_MINUTES=5

# 触发归集的最低 USD 阈值（低于此金额不触发）
SWEEP_THRESHOLD_USD=1.0

# Solana 保留金额（用于支付 gas 费，单位：SOL）
SWEEP_RESERVE_AMOUNT_SOL=0.005

# Tron 保留金额（用于支付 gas 费，单位：TRX）
SWEEP_RESERVE_AMOUNT_TRX=1.0

# 最大重试次数
SWEEP_MAX_RETRY_COUNT=3

# 重试间隔（分钟）
SWEEP_RETRY_DELAY_MINUTES=10

# ========== 主钱包地址配置 ==========
# 资金归集的目标地址

# Solana 主钱包地址（必须配置才能进行归集）
# SOLANA_MASTER_WALLET=your_solana_master_wallet_address_here

# Tron 主钱包地址（必须配置才能进行归集）
# TRON_MASTER_WALLET=your_tron_master_wallet_address_here
