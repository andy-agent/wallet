# 区块链钱包服务 Dockerfile
# 仅暴露内网端口，不映射到宿主机

FROM python:3.11-slim

WORKDIR /app

# Use Aliyun mirrors for apt
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources || \
    sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Use Tsinghua pip mirror for faster installation in China
COPY requirements.txt .
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple -r requirements.txt

# Copy application
COPY app/ ./app/

# Copy wallet service entry point
COPY app/services/wallet_server.py ./wallet_server.py

# Expose port (仅容器内暴露，不映射到宿主机)
EXPOSE 9000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:9000/health || exit 1

# Run wallet service
CMD ["python", "wallet_server.py"]
