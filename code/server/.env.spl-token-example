# ================================================
# SPL Token Configuration Example
# 复制此文件到 .env 并根据需要修改
# ================================================

# ================================================
# Database (Required)
# ================================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost/v2rayng_payment

# ================================================
# JWT (Required)
# ================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ================================================
# Encryption (Required)
# ================================================
ENCRYPTION_MASTER_KEY=your-32-byte-encryption-key-hex

# ================================================
# Marzban Integration (Required)
# ================================================
MARZBAN_BASE_URL=https://your-marzban-instance.com
MARZBAN_ADMIN_USERNAME=admin
MARZBAN_ADMIN_PASSWORD=your-password

# ================================================
# Solana Configuration
# ================================================
# Devnet for testing
SOLANA_RPC_URL=https://api.devnet.solana.com
# Mainnet for production
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

SOLANA_CONFIRMATIONS=12
SOLANA_MOCK_MODE=false

# ================================================
# SPL Token Configuration
# ================================================
# Token Mint Address (Contract Address)
SPL_TOKEN_MINT=8zFP8GeszFz7FvuHesguekTxDjm4KLsJEYBZTKyMLEoE

# Token Decimals (USDC/USDT typically use 6)
SPL_TOKEN_DECIMALS=6

# Token Symbol for display
SPL_TOKEN_SYMBOL=USDC

# Enable SPL Token payments
SPL_TOKEN_ENABLED=true

# ================================================
# Tron Configuration (for USDT_TRC20)
# ================================================
TRON_RPC_URL=https://nile.trongrid.io
TRON_USDT_CONTRACT=TXYZopYRdj2D9XRtbG411XZZ3kpm5bGnNF
TRON_CONFIRMATIONS=19
TRON_MOCK_MODE=false

# ================================================
# Redis (Optional - for caching)
# ================================================
REDIS_URL=redis://localhost:6379/0

# ================================================
# Application Settings
# ================================================
DEBUG=false
APP_ENV=production
ADMIN_TOKEN=your-admin-token-for-api-access

# ================================================
# Order Settings
# ================================================
ORDER_EXPIRE_MINUTES=15
ORDER_AMOUNT_TOLERANCE=0.001

# ================================================
# Worker Settings
# ================================================
WORKER_ENABLED=true
WORKER_SCAN_INTERVAL_SECONDS=10
