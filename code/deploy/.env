# Payment Bridge 测试服务器环境变量配置
# 服务器: 154.36.173.184
# 约束: 不使用443端口，数据库SSL连接

# ============================================
# 应用配置
# ============================================
APP_ENV=production
DEBUG=false

# ============================================
# 数据库配置 (容器内部连接，无需 SSL)
# ============================================
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment_secure_pass_2024
POSTGRES_DB=payment_db
DATABASE_URL=postgresql+asyncpg://payment:payment_secure_pass_2024@postgres:5432/payment_db

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# JWT 配置 (请使用强密码)
# 生成命令: openssl rand -hex 32
# ============================================
JWT_SECRET=change-me-in-production-use-strong-secret-key-32bytes

# ============================================
# 加密主密钥 (用于加密私钥，请使用强密码)
# 生成命令: openssl rand -base64 32
# ============================================
ENCRYPTION_MASTER_KEY=change-me-in-production-use-base64-encoded-key!!

# ============================================
# Marzban 配置
# ============================================
MARZBAN_BASE_URL=https://your-marzban-domain.com
MARZBAN_ADMIN_USERNAME=admin
MARZBAN_ADMIN_PASSWORD=your-marzban-password

# ============================================
# Solana 配置 (使用 Devnet 进行测试)
# ============================================
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_MOCK_MODE=false
SOLANA_CONFIRMATIONS=12

# ============================================
# Tron 配置 (使用 Nile 测试网)
# ============================================
TRON_RPC_URL=https://nile.trongrid.io
TRON_USDT_CONTRACT=TXYZopYRdj2D9XRtbG411XZZ3kpm5bGnNF
TRON_MOCK_MODE=false
TRON_CONFIRMATIONS=19

# ============================================
# 订单配置
# ============================================
ORDER_EXPIRE_MINUTES=15
ORDER_AMOUNT_TOLERANCE=0.001

# ============================================
# Worker 配置
# ============================================
WORKER_ENABLED=true
WORKER_SCAN_INTERVAL_SECONDS=10

# ============================================
# 管理员 Token (用于管理 API)
# 生成命令: openssl rand -hex 16
# ============================================
ADMIN_TOKEN=admin-token-change-me-in-production

# ============================================
# 端口配置 (测试服务器不使用443)
# ============================================
API_PORT=8080
HTTPS_PORT=8443
