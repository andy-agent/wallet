# =============================================================================
# v2rayng-payment-bridge 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值
# 警告：生产环境请使用强密码和密钥，不要提交到版本控制
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------
# 运行环境: development, staging, production
APP_ENV=production

# 调试模式（生产环境必须设为 false）
DEBUG=false

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
DB_USER=payment
DB_PASSWORD=your-strong-db-password-here
DB_NAME=v2rayng_payment
DB_PORT=5432

# 完整数据库 URL（如果使用外部数据库，直接配置此项）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# JWT 配置
# -----------------------------------------------------------------------------
# JWT 签名密钥（生成方式：openssl rand -hex 32）
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# JWT Token 过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200
JWT_REFRESH_TOKEN_EXPIRE_DAYS=90

# -----------------------------------------------------------------------------
# 加密配置
# -----------------------------------------------------------------------------
# 数据加密主密钥（生成方式：openssl rand -base64 32）
ENCRYPTION_MASTER_KEY=your-encryption-master-key-32bytes-base64

# -----------------------------------------------------------------------------
# Marzban 配置
# -----------------------------------------------------------------------------
# Marzban 服务地址
MARZBAN_BASE_URL=https://marzban.example.com

# Marzban 管理员账号
MARZBAN_ADMIN_USERNAME=admin
MARZBAN_ADMIN_PASSWORD=your-marzban-admin-password

# -----------------------------------------------------------------------------
# Solana 配置
# -----------------------------------------------------------------------------
# RPC 节点地址
# 主网: https://api.mainnet-beta.solana.com
# 开发网: https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# 最小确认数
SOLANA_CONFIRMATIONS=12

# Mock 模式（仅用于测试）
SOLANA_MOCK_MODE=false

# -----------------------------------------------------------------------------
# Tron 配置
# -----------------------------------------------------------------------------
# RPC 节点地址
# 主网: https://api.trongrid.io
# Nile 测试网: https://nile.trongrid.io
TRON_RPC_URL=https://api.trongrid.io

# USDT TRC20 合约地址
# 主网: TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# Nile 测试网: TXYZopYRdj2D9XRtbG411XZZ3kpm5bGnNF
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# 最小确认数
TRON_CONFIRMATIONS=19

# Mock 模式（仅用于测试）
TRON_MOCK_MODE=false

# -----------------------------------------------------------------------------
# 订单配置
# -----------------------------------------------------------------------------
# 订单过期时间（分钟）
ORDER_EXPIRE_MINUTES=15

# 金额容差（0.001 = 0.1%）
ORDER_AMOUNT_TOLERANCE=0.001

# -----------------------------------------------------------------------------
# Worker 配置
# -----------------------------------------------------------------------------
# 是否启用 Worker（API 实例设为 false，Worker 实例设为 true）
WORKER_ENABLED=true

# 扫描间隔（秒）
WORKER_SCAN_INTERVAL_SECONDS=10

# -----------------------------------------------------------------------------
# 管理端配置
# -----------------------------------------------------------------------------
# 管理员 Token（用于访问管理接口）
ADMIN_TOKEN=your-admin-token-for-management-api

# -----------------------------------------------------------------------------
# 端口配置（Docker Compose 使用）
# -----------------------------------------------------------------------------
API_PORT=8000
NGINX_PORT=80
NGINX_SSL_PORT=443
