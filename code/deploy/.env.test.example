# 测试服务器环境变量配置 (154.36.173.184)
# 约束: 不使用443端口，数据库SSL连接

# 应用配置
APP_ENV=production
DEBUG=false

# 数据库配置 (SSL连接)
# 格式: postgresql+asyncpg://user:pass@host:port/db?sslmode=require
DATABASE_URL=postgresql+asyncpg://payment:payment_pass@postgres:5432/payment_db?sslmode=require

# Redis配置
REDIS_URL=redis://redis:6379/0

# JWT配置 (请使用强密码)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 加密主密钥 (用于加密私钥，请使用强密码)
ENCRYPTION_MASTER_KEY=your-super-secret-encryption-key-32bytes!

# Marzban配置
MARZBAN_BASE_URL=https://your-marzban-domain.com
MARZBAN_ADMIN_USERNAME=admin
MARZBAN_ADMIN_PASSWORD=your-marzban-password

# Solana配置
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CONFIRMATIONS=12
SOLANA_MOCK_MODE=false

# Tron配置
TRON_RPC_URL=https://nile.trongrid.io
TRON_CONFIRMATIONS=19
TRON_USDT_CONTRACT=TXYZopYRdj2D9XRtbG411XZZ3kpm5bGnNF
TRON_MOCK_MODE=false

# 订单配置
ORDER_EXPIRE_MINUTES=15
ORDER_AMOUNT_TOLERANCE=0.001

# Worker配置
WORKER_ENABLED=true
WORKER_SCAN_INTERVAL_SECONDS=10

# 管理员Token (用于管理API)
ADMIN_TOKEN=your-admin-token-for-testing

# 端口配置 (测试服务器不使用443)
API_PORT=8080
HTTPS_PORT=8443
